# Mneme API Configuration Example
# Copy this to .env and customize

# Server Configuration
MNEME_API_HOST=0.0.0.0
MNEME_API_PORT=8000

# Database
MNEME_DATABASE_URL=sqlite:///./mneme.db

# Security
MNEME_SECRET_KEY=your-super-secret-key-change-this
MNEME_ADMIN_PASSWORD=admin

# Token expiry (in minutes)
MNEME_ACCESS_TOKEN_MINUTES=720

# API URL used by worker
MNEME_API_URL=http://localhost:8000

# AI provider routing (anthropic | openai | google | ollama)
MODEL_PROVIDER=ollama
AGENT_MAX_ITERATIONS=30

# Anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-5

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# Google
GOOGLE_API_KEY=
GOOGLE_MODEL=gemini-2.5-pro

# Ollama local/free
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1

# Claude Execution
CLAUDE_CODE_COMMAND='claude --print --allowedTools "Edit,Write,Bash" {prompt_file}'
CLAUDE_CODE_TIMEOUT_SECONDS=900
CLAUDE_CODE_MAX_RETRIES=1
CLAUDE_CODE_RETRY_DELAY_SECONDS=3
CLAUDE_ARTIFACT_DIR=
ALLOW_MOCK_CLAUDE_FOR_TESTS=false
ENABLE_MOCK_CLAUDE_EXECUTION=false

# GitHub PAT integration
GITHUB_TOKEN=
GITHUB_WORKSPACE_DIR=

# Mobile Notifications (Telegram)
NOTIFICATIONS_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
PUBLIC_DASHBOARD_URL=
